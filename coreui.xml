            </Layer>
            <Layer level="HIGHLIGHT">
                <Texture parentKey="Highlight" setAllPoints="true" alphaMode="ADD">
                    <Color r="0" g="1" b="0" a="0.2"/>
                </Texture>
            </Layer>
        </Layers>
    </Frame>

